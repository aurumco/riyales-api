{
  "app_name": "Riyales",
  "remote_config_url": "https://raw.githubusercontent.com/aurumco/riyales-api/refs/heads/main/api/v1/config/app_config.json",
  "api_endpoints": {
    "currency_url": "https://raw.githubusercontent.com/aurumco/riyales-api/main/api/v1/market/currency.json",
    "gold_url": "https://raw.githubusercontent.com/aurumco/riyales-api/main/api/v1/market/gold.json",
    "commodity_url": "https://raw.githubusercontent.com/aurumco/riyales-api/main/api/v1/market/commodity.json",
    "crypto_url": "https://raw.githubusercontent.com/aurumco/riyales-api/main/api/v1/market/cryptocurrency.json",
    "stock_debt_securities_url": "https://raw.githubusercontent.com/aurumco/riyales-api/main/api/v1/market/stock/debt_securities.json",
    "stock_futures_url": "https://raw.githubusercontent.com/aurumco/riyales-api/main/api/v1/market/stock/futures.json",
    "stock_housing_facilities_url": "https://raw.githubusercontent.com/aurumco/riyales-api/main/api/v1/market/stock/housing_facilities.json",
    "stock_tse_ifb_symbols_url": "https://raw.githubusercontent.com/aurumco/riyales-api/main/api/v1/market/stock/tse_ifb_symbols.json",
    "priority_assets_url": "https://raw.githubusercontent.com/aurumco/riyales-api/refs/heads/main/api/v1/config/priority_assets.json",
    "currency_flags_url": "https://raw.githubusercontent.com/aurumco/riyales-api/refs/heads/main/api/v1/config/currency_flags.json"
  },
  "priceUpdateIntervalMinutes": 5,
  "update_interval_ms": 30000,
  "supported_locales": ["en", "fa"],
  "default_locale": "en",
  "theme_options": {
    "default_theme": "light",
    "light": {
      "brightness": "light",
      "primaryColor": "#FFFFFF",
      "backgroundColor": "#F8F9FA",
      "scaffoldBackgroundColor": "#F8F9FA",
      "appBarColor": "#FFFFFF",
      "cardColor": "#FFFFFF",
      "textColor": "#1E1E1E",
      "secondaryTextColor": "#525252",
      "accentColorGreen": "#00C851",
      "accentColorRed": "#FF4444",
      "cardBorderRadius": 16.0,
      "shadowColor": "#000000",
      "shadowOpacity": 0.1,
      "shadowBlurRadius": 8.0,
      "shadowSpreadRadius": 2.0,
      "shadowOffsetX": 0.0,
      "shadowOffsetY": 2.0,
      "indicatorColor": "#00C851",
      "indicatorBlurRadius": 3.0,
      "indicatorNeonOpacity": 0.7,
      "indicatorEdgeFadeWidth": 4.0
    },
    "dark": {
      "brightness": "dark",
      "primaryColor": "#1A1A2E",
      "backgroundColor": "#121212",
      "scaffoldBackgroundColor": "#121212",
      "appBarColor": "#1E1E1E",
      "cardColor": "#1E1E1E",
      "textColor": "#E0E0E0",
      "secondaryTextColor": "#A0A0A0",
      "accentColorGreen": "#00C851",
      "accentColorRed": "#FF4444",
      "cardBorderRadius": 16.0,
      "shadowColor": "#000000",
      "shadowOpacity": 0.2,
      "shadowBlurRadius": 10.0,
      "shadowSpreadRadius": 2.0,
      "shadowOffsetX": 0.0,
      "shadowOffsetY": 3.0,
      "indicatorColor": "#00C851",
      "indicatorBlurRadius": 3.0,
      "indicatorNeonOpacity": 0.8,
      "indicatorEdgeFadeWidth": 4.0
    }
  },
  "fonts": {
    "persianFontFamily": "Vazirmatn",
    "englishFontFamily": "Roboto",
    "fontWeightLight": 300,
    "fontWeightRegular": 400,
    "fontWeightMedium": 500,
    "fontWeightBold": 700,
    "fontScalingFactor": 1.0,
    "letterSpacing": 0.15
  },
  "splashScreen": {
    "durationSeconds": 1.0,
    "iconPath": "assets/images/splash-screen.png",
    "iconWidth": 0.4,
    "topMarginFraction": 0.33,
    "bottomMarginFraction": 0.15,
    "loadingIndicatorColor": "#00C851",
    "loadingIndicatorSize": 12.0,
    "loadingIndicatorStrokeWidth": 2.0,
    "loadingAnimationSpeedFactor": 1.0,
    "backgroundColor": "dynamic" 
  },
  "animation": {
    "cardTapAnimationDuration": 150,
    "cardLongPressAnimationDuration": 300,
    "pageTransitionDuration": 300,
    "tabSwitchAnimationDuration": 250,
    "lazyLoadAnimationDuration": 300,
    "refreshAnimationDuration": 800,
    "splashWaveAnimationDuration": 1000,
    "favoriteToggleAnimationDuration": 300,
    "fabMenuAnimationDuration": 250
  },
  "haptics": {
    "enableHapticFeedback": true,
    "favoriteToggleDuration": 50,
    "tabSwitchDuration": 10,
    "cardTapDuration": 15,
    "errorFeedbackDuration": 100
  },
  "itemsPerLazyLoad": 20,
  "initialItemsToLoad": 20,
  "cryptoIconFilter": {
    "brightness": 0.0,
    "contrast": 0.0,
    "saturation": -0.2
  },
  "cardLayout": {
    "aspectRatio": 1.0,
    "horizontalSpacing": 6.0,
    "verticalSpacing": 6.0,
    "padding": 12.0,
    "gridColumnsMobile": 2,
    "gridColumnsTablet": 3,
    "gridColumnsDesktop": 5,
    "gridBreakpointTablet": 600,
    "gridBreakpointDesktop": 1200,
    "logoPositionTop": 8.0,
    "logoPositionLeft": 8.0,
    "logoSize": 24.0,
    "titlePositionTop": 8.0,
    "titlePositionRight": 8.0,
    "symbolBadgeHeight": 20.0,
    "symbolBadgeHorizontalPadding": 8.0,
    "badgeMargin": 4.0,
    "badgeRadius": 10.0,
    "favoriteIconSize": 16.0,
    "priceTextSize": 16.0,
    "changePercentSize": 14.0,
    "elevation": 1.0,
    "cardInnerPadding": 12.0
  },
  "feature_flags": {
    "enable_chat": false,
    "enable_notifications": true,
    "enable_fab_menu_for_stock": true,
    "load_tab_data_on_demand": true,
    "preload_currency_tab": true,
    "enable_pinning_on_long_press": true,
    "enable_tap_to_details": false
  },
  "spotlightEffect": {
    "opacity": 0.2,
    "blurRadius": 10.0,
    "spreadRadius": 2.0,
    "enabled": true,
    "gradientStartX": 0.0,
    "gradientStartY": 0.0,
    "gradientEndX": 0.3,
    "gradientEndY": 0.3,
    "useCountryFlagColor": true
  },
  "bottomSheet": {
    "cornerRadius": 16.0,
    "initialChildSize": 0.5,
    "minChildSize": 0.25,
    "maxChildSize": 0.85,
    "snapPoints": [0.25, 0.5, 0.85],
    "enableDrag": true,
    "backdropOpacity": 0.5,
    "animation": {
      "duration": 300,
      "curve": "easeInOut"
    }
  },
  "fabMenu": {
    "mainButtonSize": 56.0,
    "childButtonSize": 48.0,
    "spacing": 10.0,
    "childButtonElevation": 4.0,
    "mainButtonElevation": 6.0,
    "backgroundColor": "#00C851",
    "foregroundColor": "#FFFFFF",
    "openAnimationDuration": 300,
    "closeAnimationDuration": 200,
    "labelBackgroundColor": "#333333",
    "labelTextColor": "#FFFFFF",
    "labelPadding": 8.0,
    "labelCornerRadius": 4.0
  },
  "pin": {
    "enablePinBadge": true,
    "pinBadgeColor": "#FFC107",
    "pinBadgeSize": 18.0,
    "pinIconSize": 12.0,
    "pinIconColor": "#FFFFFF",
    "pinAnimationDuration": 300,
    "maxPinnedItems": 10
  }
}